# ╔══════════════════════════════════════════════════════════════════╗
# ║  GPTHub — Self-Hosted Deployment Configuration                 ║
# ║  Copy this file: cp .env.example .env                          ║
# ║  Then edit .env with your values before running docker compose  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── REQUIRED ──────────────────────────────────────────────────────

# Runtime location on the VPS:
#   /opt/gpthub/.env
# The deploy workflow copies docker-compose.prod.yml there automatically.
# Keep only secrets and runtime overrides in that external .env file.

# OpenAI-compatible API endpoint (MWS GPT, OpenAI, etc.)
OPENAI_API_BASE_URL=https://api.gpt.mws.ru/v1

# API key for the endpoint above
OPENAI_API_KEY=your-api-key-here

# Secret key for session encryption (change to a random string)
WEBUI_SECRET_KEY=change-me-to-random-string

# ── OPTIONAL ──────────────────────────────────────────────────────

# Host port to expose the application on
PORT=3000

# Allow new user registration (set to false for private deployments)
ENABLE_SIGNUP=false

# Default role for new users: "user" or "admin"
DEFAULT_USER_ROLE=user

# ── DATABASE ──────────────────────────────────────────────────────

# By default, SQLite is used (stored in the Docker volume).
# Uncomment to use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@host:5432/gpthub

# ── DOCKER IMAGE ──────────────────────────────────────────────────

# The deploy workflow updates this automatically when you choose a version/image.
# You can also set it manually for local pull/upgrade flows:
# GPTHUB_IMAGE=ghcr.io/it-aul/true-tech-hack-2026:0.8.12-gpthub.16
