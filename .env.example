# Docker dev (docker-compose.dev.yml): defaults disable stale SQLite overrides and optional Ollama.
# Uncomment if you need admin-saved settings in the DB to win over .env:
# ENABLE_PERSISTENT_CONFIG=true
# Uncomment if Ollama runs on the host (see Docker docs for host URL):
# ENABLE_OLLAMA_API=true

# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

# =============================================================================
# MWS GPT (OpenAI-compatible) — https://api.gpt.mws.ru/v1
# Документация: GET /v1/models, POST /v1/embeddings с model "bge-m3", POST /v1/chat/completions
# =============================================================================
OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
OPENAI_API_KEY=''

# RAG / эмбеддинги: тот же base URL и ключ, что у OPENAI_* (иначе будет 401 на /v1/embeddings)
RAG_OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
RAG_OPENAI_API_KEY=''
RAG_EMBEDDING_ENGINE='openai'
# Имя модели как в MWS (не HuggingFace-алиас baai/bge-m3)
RAG_EMBEDDING_MODEL='bge-m3'

# Распознавание речи (тот же хост при использовании MWS)
AUDIO_STT_ENGINE='openai'
AUDIO_STT_OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
AUDIO_STT_OPENAI_API_KEY=''
AUDIO_STT_MODEL='mistralai/voxtral-small-24b-2507'

# Совместимость: fallback для RAG-ключа, если RAG_OPENAI_API_KEY пуст (см. config.py)
ROUTERAI_API_URL='https://api.gpt.mws.ru/v1'
ROUTERAI_API_KEY=''
REKA_API_URL='https://api.gpt.mws.ru/v1'
REKA_API_KEY=''
REKA_ROUTER_MODEL='rekaai/reka-edge'

# Auto-route LLM-классификатор (опционально; список моделей: GET https://api.gpt.mws.ru/v1/models)
# ROUTER_MODEL='gpt-oss-20b'
# ROUTER_API_BASE_URL='https://api.gpt.mws.ru/v1'
# ROUTER_API_KEY=''
# ROUTER_MAX_TOKENS=384
# ROUTER_TEMPERATURE=0.2

# Auto-route upstream failover (when model is "auto" or auto_route: try next ranked model on provider errors)
# AUTO_ROUTE_FAILOVER_MAX=15
# AUTO_ROUTE_FAILOVER_HTTP_STATUSES=400,404,408,429,502,503,504
# AUTO_ROUTE_FAILOVER_BODY_SUBSTRINGS=no available providers,model_not_found,unavailable,overload,overloaded,rate limit

# Auto-route: prior dialog context + cache (see docs/API_CHANGES.md)
# ROUTER_CONTEXT_MAX_MESSAGES=8
# ROUTER_CONTEXT_MAX_CHARS=3000
# ROUTER_SHORT_MESSAGE_LEN=24
# Do not merge recent dialog into semantic/router query when last message is this long (0 = disable).
# ROUTER_CONTEXT_NO_MERGE_MIN_CHARS=96
# ROUTER_DISABLE_ROUTING_CACHE=false
# Append system hint: last user turn is primary; earlier turns are context (multi-turn threads).
# ENABLE_CHAT_LAST_TURN_PRIORITY_HINT=false
# Attached image: context for adjudicator (True) vs legacy «any image → force vision/VLM» (False).
# ROUTER_SOFT_IMAGE_ATTACHMENT=true

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
